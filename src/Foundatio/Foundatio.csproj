<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!-- Required by the vendored Cronos parser (src/Foundatio/Cronos), which uses unsafe pointer parsing. -->
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>
  <ItemGroup>
    <!-- Can be removed when lowest TFM is net 8 -->
    <PackageReference Include="Microsoft.Bcl.TimeProvider" Version="8.0" />

    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="8.0" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="8.0" />
    <!-- IHostedService/BackgroundService for the durable job-runtime pump that UseRuntimeStore registers, so a
         configured runtime store actually drains (jobs run; the messaging delayed-delivery fallback fires). -->
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" Version="8.0" />
  </ItemGroup>
</Project>
